---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sortedArticles = allArticles.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const featured = sortedArticles.find((a) => a.data.featured) || sortedArticles[0];
const recent = sortedArticles.filter((a) => a.slug !== featured?.slug).slice(0, 9);

const categories = [
  {
    slug: 'care-guide',
    label: 'Care guides',
    description: 'Watering, lighting, troubleshooting — the fundamentals.',
    emoji: '💧',
    color: 'moss',
  },
  {
    slug: 'plant-profile',
    label: 'Plant profiles',
    description: 'Deep dives on each species that actually thrives in glass.',
    emoji: '🌿',
    color: 'glass',
  },
  {
    slug: 'sourcing',
    label: 'Sourcing',
    description: 'Moss, springtails, driftwood — where to find the good stuff.',
    emoji: '🪨',
    color: 'soil',
  },
  {
    slug: 'problem-solving',
    label: 'Problem solving',
    description: "Something dying? Start here.",
    emoji: '🩺',
    color: 'red',
  },
];
---

<BaseLayout
  title="Terrarium knowledge, finally in one place"
  description="Mossroom is the honest hub for terrarium builders — care guides, plant profiles, sourcing tips, and problem-solving, all written by people who are figuring it out, alongside you."
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-moss-100 to-moss-50 py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="badge badge-care mb-4">🌿 Built by hobbyists, for hobbyists</span>
        <h1 class="font-serif text-4xl md:text-6xl font-bold text-moss-900 leading-tight mb-6">
          Everything you need to keep a tiny world alive.
        </h1>
        <p class="text-xl text-soil-700 mb-8 leading-relaxed">
          If you've ever killed a terrarium and didn't know why, you're in the right
          place. Mossroom is the knowledge hub for people figuring this out — together.
          Clear answers, honest about what we don't know, no fake expertise.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/articles" class="btn-primary">
            Browse all guides →
          </a>
          <a href="#newsletter" class="btn-secondary">
            Get a weekly terrarium tip
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-3xl font-bold text-moss-900 mb-2">Where to start</h2>
      <p class="text-soil-600 mb-10">Pick a thread. We'll meet you there.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {categories.map((cat) => (
          <a
            href={`/categories/${cat.slug}`}
            class="block p-6 rounded-xl border border-moss-200 hover:border-moss-400 hover:shadow-md transition-all bg-white"
          >
            <div class="text-3xl mb-3">{cat.emoji}</div>
            <h3 class="font-serif text-xl font-bold text-moss-800 mb-2">{cat.label}</h3>
            <p class="text-sm text-soil-600">{cat.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured -->
  {featured && (
    <section class="py-16 bg-moss-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-8">
          <div>
            <span class="text-xs uppercase tracking-wider text-moss-600 font-semibold">Featured</span>
            <h2 class="font-serif text-3xl font-bold text-moss-900 mt-1">This week's deep read</h2>
          </div>
          <a href="/articles" class="hidden sm:inline text-moss-600 hover:text-moss-800 text-sm font-medium">
            All guides →
          </a>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div class="lg:col-span-2">
            <ArticleCard article={featured} />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-6">
            {recent.slice(0, 2).map((a) => <ArticleCard article={a} />)}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Recent grid -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-3xl font-bold text-moss-900 mb-8">Latest from the Mossroom</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {recent.map((a) => <ArticleCard article={a} />)}
      </div>
      <div class="mt-10 text-center">
        <a href="/articles" class="btn-secondary">Browse all articles</a>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section id="newsletter" class="py-20 bg-moss-700 text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-serif text-3xl md:text-4xl font-bold mb-4">
        The newsletter is coming soon.
      </h2>
      <p class="text-moss-100 mb-8 text-lg">
        One small thing every Friday — a single terrarium tip, one question from the
        community, and a beautiful build from a reader. We're setting it up properly
        before launching (we don't want to send you broken stuff).
      </p>
      <p class="text-moss-200 mb-2">
        For now, <a href={SITE.discordUrl} class="underline text-white hover:text-moss-200 font-medium">join the Discord</a> — that's where the fast help lives.
      </p>
      <p class="text-xs text-moss-200 mt-6">
        Want a heads-up when the newsletter launches? Drop your email in the Discord #welcome channel.
      </p>
    </div>
  </section>
</BaseLayout>
