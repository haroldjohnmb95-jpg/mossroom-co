---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../config';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: article,
  }));
}

type Props = CollectionEntry<'articles'>;
const article = Astro.props;
const { Content } = await article.render();

const articleUrl = `https://mossroom.co/articles/${article.slug}`;
const articleTitle = article.data.title;

// Find related articles: same category first, then matching tags, exclude self
const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const related = allArticles
  .filter((a) => a.slug !== article.slug)
  .map((a) => {
    let score = 0;
    if (a.data.category === article.data.category) score += 3;
    const sharedTags = a.data.tags.filter((t) => article.data.tags.includes(t)).length;
    score += sharedTags;
    return { article: a, score };
  })
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map((x) => x.article);

const shareLinks = [
  {
    name: 'X / Twitter',
    href: `https://twitter.com/intent/tweet?text=${encodeURIComponent(articleTitle)}&url=${encodeURIComponent(articleUrl)}`,
    icon: '𝕏',
  },
  {
    name: 'Reddit',
    href: `https://www.reddit.com/submit?url=${encodeURIComponent(articleUrl)}&title=${encodeURIComponent(articleTitle)}`,
    icon: '◉',
  },
  {
    name: 'Discord',
    href: SITE.discordUrl,
    icon: '💬',
  },
  {
    name: 'Email',
    href: `mailto:?subject=${encodeURIComponent(articleTitle)}&body=${encodeURIComponent(`Check this out: ${articleUrl}`)}`,
    icon: '✉',
  },
];

const categoryLabels: Record<string, string> = {
  'care-guide': 'Care guide',
  'plant-profile': 'Plant profile',
  sourcing: 'Sourcing',
  'problem-solving': 'Problem solving',
  inspiration: 'Inspiration',
  beginner: 'Beginner',
};

const categoryColors: Record<string, string> = {
  'care-guide': 'badge-care',
  'plant-profile': 'badge-plant',
  sourcing: 'badge-source',
  'problem-solving': 'badge-problem',
  inspiration: 'badge-inspiration',
  beginner: 'badge-beginner',
};
---

<BaseLayout
  title={article.data.title}
  description={article.data.description}
  type="article"
  publishedDate={article.data.pubDate}
  author={article.data.author}
>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <nav class="text-sm text-soil-500 mb-6">
      <a href="/" class="hover:text-moss-700">Home</a> ›
      <a href="/articles" class="hover:text-moss-700">Guides</a> ›
      <a href={`/categories/${article.data.category}`} class="hover:text-moss-700 capitalize">
        {categoryLabels[article.data.category]}
      </a>
    </nav>

    <header class="mb-10">
      <div class="flex items-center gap-2 mb-4 flex-wrap">
        <span class={`badge ${categoryColors[article.data.category]}`}>
          {categoryLabels[article.data.category]}
        </span>
        {article.data.difficulty && (
          <span class="badge bg-soil-100 text-soil-700 capitalize">
            {article.data.difficulty}
          </span>
        )}
        {article.data.tags.slice(0, 3).map((tag) => (
          <span class="badge bg-moss-50 text-moss-700">#{tag}</span>
        ))}
      </div>

      <h1 class="font-serif text-4xl md:text-5xl font-bold text-moss-900 leading-tight mb-5">
        {article.data.title}
      </h1>
      <p class="text-xl text-soil-700 leading-relaxed mb-6">
        {article.data.description}
      </p>
      <div class="flex items-center gap-4 text-sm text-soil-500 pb-6 border-b border-moss-200">
        <span>By {article.data.author}</span>
        <span>·</span>
        <time datetime={article.data.pubDate.toISOString()}>
          {article.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </time>
        {article.data.readingTime && (
          <>
            <span>·</span>
            <span>{article.data.readingTime} min read</span>
          </>
        )}
      </div>
    </header>

    {article.data.cover && (
      <figure class="mb-10">
        <img
          src={article.data.cover.src}
          alt={article.data.coverAlt || article.data.title}
          class="w-full rounded-2xl shadow-md"
        />
        {article.data.coverAlt && (
          <figcaption class="text-sm text-soil-500 text-center mt-3 italic">
            {article.data.coverAlt}
          </figcaption>
        )}
      </figure>
    )}

    <div class="prose-moss">
      <Content />
    </div>

    {related.length > 0 && (
      <section class="mt-16 pt-8 border-t border-moss-200">
        <h3 class="font-serif text-2xl font-bold text-moss-900 mb-6">More from Mossroom</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
          {related.map((r) => (
            <a
              href={`/articles/${r.slug}`}
              class="block bg-white border border-moss-200 hover:border-moss-400 rounded-xl p-5 transition-all hover:shadow-md group"
            >
              <span class={`badge ${categoryColors[r.data.category]} mb-2`}>
                {categoryLabels[r.data.category]}
              </span>
              <h4 class="font-serif text-base font-bold text-moss-800 group-hover:text-moss-600 leading-snug mb-2">
                {r.data.title}
              </h4>
              <p class="text-sm text-soil-600 line-clamp-2">{r.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <footer class="mt-16 pt-8 border-t border-moss-200">
      <div class="bg-moss-50 border border-moss-200 rounded-xl p-6 mb-8">
        <h3 class="font-serif text-xl font-bold text-moss-800 mb-2">
          Got questions?
        </h3>
        <p class="text-soil-700 mb-4">
          Drop into the Mossroom Discord — over 200 builders sharing builds, troubleshooting
          dying plants, and trading springtail cultures.
        </p>
        <a href={SITE.discordUrl} class="btn-primary">Join the community →</a>
      </div>

      <div class="flex items-center justify-between flex-wrap gap-4">
        <p class="text-sm text-soil-500">
          Found this helpful? Share it with a fellow builder.
        </p>
        <div class="flex flex-wrap items-center gap-2">
          {shareLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener"
              aria-label={`Share on ${link.name}`}
              class="inline-flex items-center gap-1.5 bg-white hover:bg-moss-50 border border-moss-200 hover:border-moss-400 text-soil-700 hover:text-moss-800 text-sm font-medium px-3 py-1.5 rounded-md transition-colors"
            >
              <span class="text-base">{link.icon}</span>
              <span>{link.name}</span>
            </a>
          ))}
          <button
            type="button"
            data-copy-url={articleUrl}
            aria-label="Copy link to clipboard"
            class="copy-link-btn inline-flex items-center gap-1.5 bg-white hover:bg-moss-50 border border-moss-200 hover:border-moss-400 text-soil-700 hover:text-moss-800 text-sm font-medium px-3 py-1.5 rounded-md transition-colors"
          >
            <span class="text-base">🔗</span>
            <span class="copy-link-text">Copy link</span>
          </button>
        </div>
      </div>
    </footer>
  </article>
</BaseLayout>

<script>
  document.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('.copy-link-btn');
    if (!btn) return;
    e.preventDefault();
    const url = btn.getAttribute('data-copy-url');
    if (!url) return;
    try {
      await navigator.clipboard.writeText(url);
      const textEl = btn.querySelector('.copy-link-text');
      if (textEl) {
        const original = textEl.textContent;
        textEl.textContent = 'Copied!';
        setTimeout(() => {
          if (textEl.textContent === 'Copied!') textEl.textContent = original;
        }, 2000);
      }
    } catch {
      const input = document.createElement('input');
      input.value = url;
      document.body.appendChild(input);
      input.select();
      try { document.execCommand('copy'); } catch {}
      document.body.removeChild(input);
    }
  });
</script>
