---
import { SITE } from '../config';

const year = new Date().getFullYear();
---

<footer class="bg-moss-900 text-moss-100 mt-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-2xl">🌿</span>
          <span class="font-serif text-xl font-bold text-white">Mossroom</span>
        </div>
        <p class="text-moss-200 text-sm leading-relaxed max-w-md">
          The trusted knowledge hub for terrarium builders. Care guides, plant
          profiles, sourcing tips — written by people who actually keep them alive.
        </p>
        <div class="mt-4">
          <a
            href={SITE.discordUrl}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 bg-moss-700 hover:bg-moss-600 text-white text-sm font-medium px-4 py-2 rounded-md transition-colors"
          >
            💬 Join the community
          </a>
        </div>
      </div>

      <div>
        <h4 class="font-semibold text-white mb-3 text-sm uppercase tracking-wider">Explore</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/articles" class="text-moss-200 hover:text-white">All guides</a></li>
          <li><a href="/categories/care-guide" class="text-moss-200 hover:text-white">Care guides</a></li>
          <li><a href="/categories/plant-profile" class="text-moss-200 hover:text-white">Plant profiles</a></li>
          <li><a href="/categories/sourcing" class="text-moss-200 hover:text-white">Sourcing</a></li>
          <li><a href="/categories/problem-solving" class="text-moss-200 hover:text-white">Problem solving</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-white mb-3 text-sm uppercase tracking-wider">Mossroom</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/about" class="text-moss-200 hover:text-white">About</a></li>
          <li><a href="/rss.xml" class="text-moss-200 hover:text-white">RSS feed</a></li>
          <li><a href="/sitemap-index.xml" class="text-moss-200 hover:text-white">Sitemap</a></li>
          <li>
            <a href="mailto:hello@mossroom.co" class="text-moss-200 hover:text-white">
              hello@mossroom.co
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-moss-800 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-moss-300">
        © {year} Mossroom. Made for people who keep tiny worlds alive.
      </p>
      <p class="text-xs text-moss-300">
        Built on Cloudflare Pages. Hosted on the edge. Powered by community.
      </p>
    </div>
  </div>
</footer>